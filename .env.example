# Voxera runtime environment (example values only; do not commit secrets)

# Queue runtime
VOXERA_QUEUE_ROOT=./notes/queue
VOXERA_QUEUE_LOCK_STALE_S=3600
# VOXERA_QUEUE_FAILED_MAX_AGE_S=86400
# VOXERA_QUEUE_FAILED_MAX_COUNT=200

# Panel runtime
VOXERA_PANEL_HOST=127.0.0.1
VOXERA_PANEL_PORT=8787
VOXERA_PANEL_OPERATOR_USER=admin
# Store secrets in ~/.config/voxera/env (recommended), not in repo .env
# VOXERA_PANEL_OPERATOR_PASSWORD=change-me
# VOXERA_PANEL_CSRF_ENABLED=1
# VOXERA_PANEL_ENABLE_GET_MUTATIONS=0

# Optional ops behavior
# VOXERA_OPS_BUNDLE_DIR=./notes/queue/_archive
# VOXERA_DEV_MODE=0
# VOXERA_NOTIFY=0

# systemd user services example:
# systemctl --user edit voxera-panel.service
# [Service]
# Environment=VOXERA_PANEL_OPERATOR_PASSWORD=<set-a-strong-password>
# systemctl --user daemon-reload
# systemctl --user restart voxera-panel.service voxera-daemon.service
