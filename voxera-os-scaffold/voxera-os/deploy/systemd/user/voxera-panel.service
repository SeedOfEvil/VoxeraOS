[Unit]
Description=Voxera Panel (approvals + audit UI)
After=network.target

[Service]
Type=simple
WorkingDirectory=%h/VoxeraOS/voxera-os-scaffold/voxera-os
ExecStart=%h/VoxeraOS/voxera-os-scaffold/voxera-os/.venv/bin/voxera panel --host 127.0.0.1 --port 8844
Restart=on-failure
RestartSec=2

[Install]
WantedBy=default.target
